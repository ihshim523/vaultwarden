# =============================================================================
# Vaultwarden — Self-hosted Bitwarden-compatible Password Manager
# https://vaultwarden.readthedocs.io/en/latest/usage/configuration/index.html
# =============================================================================

# ---------------------------------------------------------------------------
# Server
# Port Vaultwarden listens on (default: 80)
PORT=8080

# Bind address (0.0.0.0 = all interfaces)
LISTEN_ADDRESS=0.0.0.0

# ---------------------------------------------------------------------------
# Storage
# Database and data folder path (defaults to /data)
DATA_FOLDER=data
DB_URL=

# HIBP_API_KEY - Have I Been Pwned API key for password breach checking
# Optional: set to "" or leave unset to skip breach checking
HIBP_API_KEY=

# ---------------------------------------------------------------------------
# Admin Panel
# Token used to access the admin panel at /admin
ADMIN_TOKEN=safe-admin-token-change-me

# Enable/disable the admin panel (set to true to enable /admin)
ADMIN_ENABLED=true

# ---------------------------------------------------------------------------
# Features
# Whether new users must verify their email during signup (true/false)
SIGNUPS_VERIFY=true

# Show/hide a user's IP address from their current sessions
IP_HEADER_OPTIONAL=false
