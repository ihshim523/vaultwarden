# =============================================================================
# Vaultwarden — Self-hosted Bitwarden-compatible Password Manager
# https://github.com/dani-garcia/vaultwarden/blob/main/.env.template
# =============================================================================

# ---------------------------------------------------------------------------
# Server
# Port Vaultwarden listens on (Railway injects PORT; keep at 8080 to match the
# healthcheck and the ROCKET_PORT below)
PORT=8080

# Bind address (0.0.0.0 = all interfaces)
ROCKET_ADDRESS=0.0.0.0

# ---------------------------------------------------------------------------
# Storage
# Data folder path — must match the Railway volume mount (/data) so the
# database and attachments persist across restarts.
DATA_FOLDER=/data

# Database connection string. Leave empty to use the bundled SQLite database.
# For PostgreSQL: postgresql://user:pass@host:5432/dbname
# For MySQL:      mysql://user:pass@host:3306/dbname
DATABASE_URL=

# ---------------------------------------------------------------------------
# Have I Been Pwned
# Optional API key for password breach checking. Leave empty to skip checks.
HIBP_API_KEY=

# ---------------------------------------------------------------------------
# Admin Panel
# Token used to access the admin panel at /admin.
# On Railway this is auto-generated (ADMIN_TOKEN=${{secret(32)}}).
ADMIN_TOKEN=change-me-to-a-long-random-secret

# Disable the admin panel. Set to true to turn it off; default false = enabled.
DISABLE_ADMIN_TOKEN=false

# ---------------------------------------------------------------------------
# Features
# Require new users to verify their email during signup (true/false)
SIGNUPS_VERIFY=false

# HTTP header used to determine the client IP (e.g. X-Real-IP).
# Leave empty to use the connection IP.
IP_HEADER=
